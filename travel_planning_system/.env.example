# API Keys for Multi-Agent Travel Planning System

# OpenRouter API Key (required for all agents - replaces OpenAI)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Generative AI API Key (required for Travel Planner Agent with Google ADK)
GOOGLE_API_KEY=your_google_api_key_here

# SerperAPI Key (required for real-time search)
SERPER_API_KEY=your_serper_api_key_here

# Agent Endpoints (default ports, change if needed)
HOTEL_AGENT_URL=http://localhost:10002
CAR_RENTAL_AGENT_URL=http://localhost:10003
TRAVEL_PLANNER_AGENT_URL=http://localhost:10001

# Optional: Other configurations
DEBUG=False
LOG_LEVEL=INFO